{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ai-light",
  "version": "0.1.0",
  "identifier": "com.ai-light.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "windows": [
      {
        "title": "AI Light",
        "width": 400,
        "height": 140,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
